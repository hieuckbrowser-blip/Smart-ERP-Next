{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": false,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/index.ts", "src/db.ts", "src/drizzle.ts", "src/schema/**/*.ts"],
  "exclude": ["node_modules", "dist", "__tests__", "src/seed.ts", "src/migrate.ts"]
}
