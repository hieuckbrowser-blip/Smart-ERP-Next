{
  "dependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.22.8",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "main": "./dist/src/index.js",
  "name": "@smart-erp/database",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate",
    "migrate": "tsx ./src/migrate.ts",
    "studio": "drizzle-kit studio"
  },
  "types": "./src/index.ts",
  "version": "0.1.0",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./drizzle": {
      "types": "./src/drizzle.ts",
      "default": "./dist/src/drizzle.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/src/schema/index.js"
    }
  }
}
