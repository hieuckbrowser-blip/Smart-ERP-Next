{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src", "__tests__"],
  "exclude": ["node_modules", "dist", "drizzle"]
}
