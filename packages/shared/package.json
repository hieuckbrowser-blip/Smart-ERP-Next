{
  "name": "@smart-erp/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./utils/formatters": {
      "types": "./dist/utils/formatters.d.ts",
      "import": "./dist/utils/formatters.js",
      "require": "./dist/utils/formatters.cjs"
    },
    "./data-contracts": {
      "types": "./dist/data-contracts.d.ts",
      "import": "./dist/data-contracts.js",
      "require": "./dist/data-contracts.cjs"
    },
    "./data-contract-registry": {
      "types": "./dist/data-contract-registry.d.ts",
      "import": "./dist/data-contract-registry.js",
      "require": "./dist/data-contract-registry.cjs"
    },
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.js",
      "require": "./dist/ui/*.cjs"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "prepare": "npm run build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@smart-erp/tsconfig": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
