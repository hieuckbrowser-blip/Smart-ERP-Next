# ──────────────────────────────────────────────────────────
# Smart ERP Next — Environment Variables
# Copy to .env:  cp .env.example .env
# Dev quick start: docker compose up -d  (works without .env)
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://smart_erp:smart_erp@localhost:5432/smart_erp
DB_USER=smart_erp
DB_PASSWORD=smart_erp
DB_PORT=5432

# ── API (port 3000 inside container, mapped to 3456) ─────
API_PORT=3456
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3457

# ── Web (port 3000 inside container, mapped to 3457) ─────
WEB_PORT=3457
NEXT_PUBLIC_API_URL=http://localhost:3456
NEXT_PUBLIC_SITE_URL=http://localhost:3457


